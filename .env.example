# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# OpenAI
OPENAI_API_KEY="sk-..."

# Webhook Server
WEBHOOK_PORT=3001
WEBHOOK_SECRET="your-webhook-secret-token"

# Custom email (Resend) — used for password reset and other transactional emails
RESEND_API_KEY="re_xxxxxxxx"
FROM_EMAIL="noreply@adjarahome.ge"

# Frontend → Backend API URL (for dev: http://localhost:3001, for prod: https://api.yourdomain.com)
VITE_API_URL="http://localhost:3001"

# Admin Credentials (build-time only — Vite prefixes with VITE_)
# ⚠️ These are NOT secure for production. Use Supabase Edge Functions + custom claims instead.
VITE_ADMIN_EMAIL_1="admin@example.com"
VITE_ADMIN_PASS_1="changeme"
VITE_ADMIN_EMAIL_2=""
VITE_ADMIN_PASS_2=""
